# Mail-to-NotebookLM Environment Variables
# Copy to .env and fill in actual values (for local development only; use GitHub Secrets for Actions)

# --- Email credentials (required) ---
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# --- Email server (optional, overrides config.yaml) ---
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587

# --- Allowed senders (optional, comma-separated, overrides config.yaml) ---
# AUTH_ALLOWED_SENDERS=user1@example.com,user2@example.com

# --- Subject key (if enabled) ---
# AUTH_SUBJECT_KEY=my-secret-key

# --- NotebookLM integration (choose one) ---

# Option A: notebooklm-py (recommended for personal use)
# Run notebooklm-py locally first to authenticate via browser, then export auth JSON
# NOTEBOOKLM_AUTH_JSON={"cookies": [...]}

# Option B: Enterprise API (requires Google Workspace Enterprise license)
# NOTEBOOKLM_INTEGRATION=enterprise_api
# GCP_PROJECT_NUMBER=123456789
# GCP_CREDENTIALS_JSON={"type": "service_account", ...}
